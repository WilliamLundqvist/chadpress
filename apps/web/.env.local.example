# Public WPGraphQL endpoint (used only on the server in the Phase 4 prototype home page)
WORDPRESS_GRAPHQL_URL=https://chadpress.ddev.site/graphql

# If HTTPS fails in some dev environments, the client also tries the HTTP DDEV URL when this variable is not set.
# In production, set WORDPRESS_GRAPHQL_URL to your public GraphQL endpoint and remove fallbacks in `src/lib/wordpress.ts` if you want strict behavior.
