# WPGraphQL HTTP endpoint used by Next.js **server-side** fetch (RSC).
# Must resolve and connect from the same environment as `pnpm dev` (Node), not only in the browser.
#
# If unset, `src/lib/wordpress.ts` defaults to https://chadpress.ddev.site/graphql
# and may try http in development.
#
# WORDPRESS_GRAPHQL_URL=https://chadpress.ddev.site/graphql
# WORDPRESS_GRAPHQL_URL=http://chadpress.ddev.site/graphql
# WORDPRESS_GRAPHQL_URL=http://127.0.0.1:<port>/graphql
