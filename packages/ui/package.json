{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.tsx",
    "./globals.css": "./src/globals.css",
    "./design-tokens.css": "./src/design-tokens.css",
    "./base.css": "./src/base.css",
    "./lib/*": "./src/lib/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./components/ui/*": "./src/components/ui/*.tsx",
    "./blocks": "./blocks/index.ts",
    "./blocks/*": "./blocks/*/index.ts"
  },
  "scripts": {
    "dev": "pnpm run watch:css",
    "watch:css": "tailwindcss -i ./src/globals.css -o ./dist/editor.css --watch",
    "build:css": "tailwindcss -i ./src/globals.css -o ./dist/editor.css",
    "dist": "pnpm build:css",
    "generate:registry": "node ./scripts/generate-block-registry.mjs",
    "validate:contracts": "node ./scripts/generate-block-registry.mjs && node ./scripts/validate-block-contracts.mjs && tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "react": "^19",
    "react-dom": "^19",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "latest"
  }
}
