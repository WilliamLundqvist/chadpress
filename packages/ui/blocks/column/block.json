{
  "$schema": "../block.schema.json",
  "apiVersion": 3,
  "name": "chadpress/column",
  "title": "Column",
  "category": "chadpress",
  "icon": "editor-table",
  "description": "A semantic-width column for the Chadpress Columns block.",
  "textdomain": "chadpress",
  "attributes": {
    "width": { "type": "string", "default": "full" }
  },
  "supports": {
    "innerBlocks": true,
    "allowedBlocks": [
      "chadpress/text",
      "chadpress/heading",
      "chadpress/quote",
      "chadpress/button",
      "chadpress/section",
      "chadpress/columns",
      "chadpress/card"
    ],
    "template": []
  },
  "customTailwind": {
    "styleMap": {},
    "className": ""
  },
  "customControls": {
    "toolbar": [],
    "inspector": [
      {
        "type": "select",
        "bind": "width",
        "label": "Width",
        "options": [
          "full",
          "half",
          "third",
          "two-thirds",
          "quarter",
          "three-quarters"
        ]
      }
    ]
  },
  "capabilities": [],
  "customEditor": {
    "source": "custom"
  },
  "example": {
    "attributes": {
      "width": "full"
    },
    "innerBlocks": [
      {
        "name": "chadpress/text",
        "attributes": {
          "content": "Column content",
          "align": "left"
        }
      }
    ]
  },
  "variations": []
}
