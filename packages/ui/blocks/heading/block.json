{
  "$schema": "../block.schema.json",
  "apiVersion": 3,
  "name": "chadpress/heading",
  "title": "Heading",
  "category": "chadpress",
  "icon": "heading",
  "description": "A Chadpress heading with semantic level and alignment controls.",
  "textdomain": "chadpress",

  "attributes": {
    "content": {
      "type": "string",
      "default": "",
      "richText": true,
      "tagName": "span",
      "placeholder": "Write heading…"
    },
    "level": { "type": "number", "default": 2 }
  },

  "supports": {
    "innerBlocks": false,
    "allowedBlocks": [],
    "template": []
  },

  "customTailwind": {
    "styleMap": {
      "level": {
        "1": "h1",
        "2": "h2",
        "3": "h3",
        "4": "h4",
        "5": "h5",
        "6": "h6"
      }
    },
    "className": ""
  },

  "customControls": {
    "toolbar": [
      {
        "type": "headingLevel",
        "bind": "level",
        "label": "Heading level",
        "options": [1, 2, 3, 4, 5, 6]
      }
    ],
    "inspector": []
  },

  "capabilities": ["align"],

  "customEditor": {
    "source": "custom",
    "allowedRichText": ["bold", "italic", "link"]
  },

  "example": {
    "attributes": {
      "content": "Heading",
      "level": 2,
      "align": "left"
    }
  },

  "variations": []
}
