{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "chadpress-block",
  "title": "Chadpress block contract",
  "description": "Extends WordPress block.json with chadpress-specific layers: customTailwind, customControls, and reserved composition/i18n fields.",
  "type": "object",
  "required": [
    "name",
    "title",
    "attributes",
    "supports",
    "customTailwind",
    "customControls",
    "capabilities",
    "example",
    "variations"
  ],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "apiVersion": { "type": "integer" },
    "name": { "type": "string" },
    "title": { "type": "string" },
    "category": { "type": "string" },
    "icon": { "type": "string" },
    "description": { "type": "string" },
    "textdomain": { "type": "string" },
    "attributes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "string",
              "number",
              "boolean",
              "array",
              "object",
              "integer"
            ]
          },
          "default": {},
          "richText": { "type": "boolean" },
          "tagName": { "type": "string", "minLength": 1 },
          "placeholder": { "type": "string" }
        },
        "allOf": [
          {
            "if": {
              "properties": { "richText": { "const": true } },
              "required": ["richText"]
            },
            "then": {
              "required": ["tagName", "placeholder"]
            }
          }
        ],
        "additionalProperties": true
      }
    },
    "supports": {
      "type": "object",
      "required": ["innerBlocks", "allowedBlocks", "template"],
      "properties": {
        "innerBlocks": { "type": "boolean" },
        "allowedBlocks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "template": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "customTailwind": {
      "type": "object",
      "required": ["styleMap", "className"],
      "properties": {
        "styleMap": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        },
        "className": { "type": "string" }
      },
      "additionalProperties": true
    },
    "customControls": {
      "type": "object",
      "required": ["toolbar", "inspector"],
      "properties": {
        "toolbar": {
          "type": "array",
          "items": { "$ref": "#/definitions/customControl" }
        },
        "inspector": {
          "type": "array",
          "items": { "$ref": "#/definitions/customControl" }
        }
      },
      "additionalProperties": true
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "customEditor": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": {
          "type": "string",
          "const": "custom"
        },
        "allowedRichText": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["bold", "italic", "link"]
          },
          "uniqueItems": true
        },
        "splitting": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "example": {
      "type": "object",
      "required": ["attributes"],
      "properties": {
        "attributes": {
          "type": "object",
          "additionalProperties": true
        },
        "innerBlocks": {
          "type": "array",
          "items": { "$ref": "#/definitions/exampleBlock" }
        }
      },
      "additionalProperties": false
    },
    "variations": {
      "type": "array"
    }
  },
  "definitions": {
    "exampleBlock": {
      "type": "object",
      "required": ["name", "attributes"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^chadpress/"
        },
        "attributes": {
          "type": "object",
          "additionalProperties": true
        },
        "innerBlocks": {
          "type": "array",
          "items": { "$ref": "#/definitions/exampleBlock" }
        }
      },
      "additionalProperties": false
    },
    "customControl": {
      "type": "object",
      "required": ["type", "bind", "label"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "select",
            "toggle",
            "text",
            "alignment",
            "headingLevel",
            "link"
          ]
        },
        "bind": { "type": "string" },
        "label": { "type": "string" },
        "options": {
          "type": "array",
          "items": {
            "type": ["string", "number", "boolean"]
          }
        }
      },
      "additionalProperties": true
    }
  }
}
