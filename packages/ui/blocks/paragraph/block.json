{
  "$schema": "../block.schema.json",
  "apiVersion": 3,
  "name": "core/paragraph",
  "title": "Paragraph",
  "category": "text",
  "icon": "paragraph",
  "description": "Shadow declaration for WordPress core/paragraph — maps attribute values to shadcn typography variants.",
  "textdomain": "chadpress",

  "attributes": {
    "content": { "type": "string", "default": "", "richText": true },
    "align": { "type": "string", "default": "left" }
  },

  "supports": {
    "innerBlocks": false,
    "allowedBlocks": [],
    "template": []
  },

  "customTailwind": {
    "styleMap": {
      "align": {
        "left": "start",
        "center": "center",
        "right": "end"
      }
    },
    "className": ""
  },

  "customControls": {
    "toolbar": [],
    "inspector": []
  },

  "customEditor": {
    "source": "core",
    "allowedRichText": ["bold", "italic", "link"],
    "disabledSupports": [
      "color",
      "backgroundColor",
      "fontSize",
      "__experimentalFontWeight",
      "__experimentalFontStyle",
      "__experimentalTextTransform",
      "__experimentalTextDecoration",
      "__experimentalLetterSpacing"
    ]
  },

  "variations": []
}
